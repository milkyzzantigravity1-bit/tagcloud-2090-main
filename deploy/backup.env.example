# Конфиг бэкапа. Положить в /etc/tagcloud/backup.env (chmod 600, owner tagcloud).
# Используется и backup.sh, и tagcloud-backup.service.

# --- Postgres ---
DATABASE_URL=postgres://tagcloud:CHANGE_ME@localhost:5432/tagcloud

# --- restic ---
# Backblaze B2 (10 GB free):
#   1. Создать bucket в B2 console (private).
#   2. Сгенерировать Application Key (R/W на этот bucket).
#   3. Подставить ниже:
RESTIC_REPOSITORY=b2:tagcloud-backups:/postgres
B2_ACCOUNT_ID=CHANGE_ME
B2_ACCOUNT_KEY=CHANGE_ME

# Cloudflare R2 (10 GB free, S3-совместимый) — альтернатива:
# RESTIC_REPOSITORY=s3:https://<account>.r2.cloudflarestorage.com/tagcloud-backups
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME

# Пароль для шифрования снапшотов (restic шифрует на клиенте, перед загрузкой).
# Сгенерировать: openssl rand -base64 32
# ВАЖНО: при потере пароля бэкапы не восстановить. Сохраните в менеджер паролей.
RESTIC_PASSWORD=CHANGE_ME

# Политика хранения (опционально, есть дефолты в скрипте).
# RETAIN_DAILY=7
# RETAIN_WEEKLY=4
# RETAIN_MONTHLY=6
